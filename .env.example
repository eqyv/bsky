# ================================
# BLUESKY (Source)
# ================================
BSKY_HANDLE=your-handle.bsky.social
BSKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ================================
# X / TWITTER (Target - unofficial)
# ================================
# --- Cookie-based auth (RECOMMENDED, esp. on a VPS/datacenter IP) ---
# X's login endpoint is Cloudflare-protected and blocks datacenter IPs.
# To avoid login entirely: log into X in a browser on your normal (home)
# connection, open DevTools > Application/Storage > Cookies > https://x.com,
# and copy these two values:
X_AUTH_TOKEN=
X_CT0=
#
# --- Password login (fallback; will hit Cloudflare 403 on datacenter IPs) ---
X_USERNAME=your_handle
X_EMAIL=your_email@example.com
X_PASSWORD=your_password
# Optional: TOTP/2FA secret (base32 string from your authenticator app)
X_TOTP_SECRET=
# Optional: saved session cookies path (default: storage/twitter_cookies.json)
X_COOKIES_FILE=storage/twitter_cookies.json

# ================================
# INSTAGRAM (Target - unofficial, cookie-based)
# ================================
# Instagram (unofficial)
IG_USERNAME=your_instagram_username
IG_PASSWORD=your_instagram_password
# Optional: settings file path (default: storage/instagram_settings.json)
IG_SETTINGS_FILE=storage/instagram_settings.json

# ================================
# BOT SETTINGS
# ================================
POLL_INTERVAL_SECONDS=180
LOG_LEVEL=INFO
