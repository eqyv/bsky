# ================================
# BLUESKY (Source)
# ================================
BSKY_HANDLE=your-handle.bsky.social
BSKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ================================
# X / TWITTER (Target - unofficial)
# ================================
X_AUTH_TOKEN=your_auth_token_here
X_CT0=your_ct0_here

# ================================
# INSTAGRAM (Target - unofficial, cookie-based)
# ================================
IG_SESSIONID=your_sessionid_cookie_value
IG_CSRFTOKEN=your_csrftoken_cookie_value
IG_DS_USER_ID=your_ds_user_id_cookie_value

# ================================
# BOT SETTINGS
# ================================
POLL_INTERVAL_SECONDS=180
LOG_LEVEL=INFO
